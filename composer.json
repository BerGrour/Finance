{
    "name": "finance/finance",
    "description": "Finance project on Yii2",
    "type": "project",
    "keywords": ["yii2", "framework", "finance"],
    "license": "BSD-3-Clause",
    "support": {
        "issues": "https://github.com/yiisoft/yii2/issues?state=open",
        "forum": "http://www.yiiframework.com/forum/",
        "wiki": "http://www.yiiframework.com/wiki/",
        "irc": "irc://irc.freenode.net/yii",
        "source": "https://github.com/yiisoft/yii2"
    },
    "minimum-stability": "stable",
    "repositories": [
        {
            "type": "composer",
            "url": "https://asset-packagist.org"
        }
    ],
    "require": {
        "php": ">=8.0",
        "yiisoft/yii2": "~2.0.0",
        "yiisoft/yii2-bootstrap5": "~2.0.0",
        "yiisoft/yii2-swiftmailer": "~2.1.0",
        "kartik-v/yii2-widget-select2": "^2.2",
        "yiisoft/yii2-bootstrap": "^2.0",
        "kartik-v/yii2-widget-activeform": "^1.6",
        "kartik-v/yii2-widget-datepicker": "^1.4",
        "kartik-v/yii2-widget-datetimepicker": "^1.5",
        "kartik-v/yii2-widget-fileinput": "^1.1"
    },
    "require-dev": {
        "yiisoft/yii2-debug": "~2.1.0",
        "yiisoft/yii2-gii": "~2.2.0",
        "yiisoft/yii2-faker": "~2.0.0"
    },
    "config": {
        "process-timeout": 1800,
        "fxp-asset": {
            "enabled": false
        },
        "allow-plugins": {
            "yiisoft/yii2-composer": true
        }
    },
    "autoload": {
        "psr-4": {
            "app\\": ""
        }
    },
    "scripts": {
        "post-install-cmd": [
            "yii\\composer\\Installer::postInstall"
        ],
        "post-update-cmd": [
            "yii\\composer\\Installer::postUpdate"
        ]
    }
}
